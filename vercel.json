{
  "version": 2,
  "installCommand": "python -m pip install -r requirements.txt",
  "buildCommand": "python build_vercel.py",
  "outputDirectory": "public",

  "functions": {
    "api/wsgi.py": {
      "includeFiles": "game/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/wsgi" }
  ]
}
